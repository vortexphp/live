{
    "name": "vortexphp/live",
    "description": "Server-driven Live components (Livewire-style) for Vortex PHP",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "vortexphp/framework": "^0.12"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Vortex\\Live\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vortex\\Live\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
